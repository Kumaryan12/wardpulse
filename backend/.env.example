DATABASE_URL=sqlite:///./wardpulse.db
# On Vercel, use a Postgres URL from a Marketplace integration instead.
# DATABASE_URL=postgresql://user:password@host:5432/database
# POSTGRES_URL is also supported if your integration injects that name.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=uploads
DEMO_DATA_ENABLED=true
DEMO_HISTORY_POINTS=12
DEMO_SIMULATION_ENABLED=true
DEMO_SIMULATION_MAX_READINGS_PER_NODE=96

# Optional email dispatch settings.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# DISPATCH_OFFICER_EMAIL=

# Optional WhatsApp advisory settings.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_TO_NUMBER=
